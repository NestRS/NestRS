{
	"name": "nestrs",
	"dockerComposeFile": "docker-compose.yml",
	"service": "dev",
	"workspaceFolder": "/workspaces/nestrs",
	"postCreateCommand": "cargo install --locked --path crates/nest-rs-cli",
	"customizations": {
		"vscode": {
			"extensions": [
				"rust-lang.rust-analyzer",
				"vadimcn.vscode-lldb",
				"tamasfe.even-better-toml",
				"fill-labs.dependi",
				"usernamehw.errorlens",
				"Anthropic.claude-code"
			],
			"settings": {
				"rust-analyzer.check.command": "clippy",
				"rust-analyzer.cargo.features": "all",
				"rust-analyzer.cargo.targetDir": true,
				"editor.formatOnSave": true
			}
		}
	},
	"features": {
		"ghcr.io/devcontainers/features/common-utils:2": {
			"installZsh": true,
			"configureZshAsDefaultShell": true,
			"installOhMyZsh": true
		}
	},
	"forwardPorts": [
		3001,
		3002,
		3003,
		3004
	],
	"portsAttributes": {
		"3001": {
			"label": "auth"
		},
		"3002": {
			"label": "api"
		},
		"3003": {
			"label": "assistant"
		},
		"3004": {
			"label": "live"
		}
	}
}