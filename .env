# nestrs — committed base config for the devcontainer (the recommended setup).
#
# Only OVERRIDES live here, not every setting: anything omitted falls back to the
# in-code default of the owning `#[config]` struct. Real environment variables
# always win over this file. Per-machine secrets and bare-metal overrides go in
# `.env.local` (git-ignored), never here — the secret-shaped settings (the JWT
# signing key, the OAuth client secret) live there; see `.env.example`.
#
# Precedence (highest first):
#   real env  >  .env.<NESTRS_ENV>.local  >  .env.local  >  .env.<NESTRS_ENV>  >  .env

# Postgres / Redis as the devcontainer exposes them (compose service hostnames).
# Running on bare metal? Point these at localhost in `.env.local`.
NESTRS_DATABASE__URL=postgres://nestrs:nestrs@postgres:5432/nestrs
NESTRS_QUEUE__URL=redis://redis:6379

# JWT verification key (EdDSA public key) — NOT a secret: the `api` resource
# server needs only this to verify tokens, and cannot mint them. The matching
# private signing key (the `auth` issuer's) is secret and lives in `.env.local`.
NESTRS_AUTHN__PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\nMCowBQYDK2VwAyEAHfPOjd2Y3m1BLM5nBJBMZFAlfWt69WL1NY8XyYeGfeo=\n-----END PUBLIC KEY-----\n"

# Demo OAuth2 provider (GitHub) for the `auth` issuer. The client id and provider
# URLs are not secret; the client secret is and lives in `.env.local`.
NESTRS_AUTHN__CLIENT_ID=demo-client-id
NESTRS_AUTHN__AUTH_URL=https://github.com/login/oauth/authorize
NESTRS_AUTHN__TOKEN_URL=https://github.com/login/oauth/access_token
NESTRS_AUTHN__USERINFO_URL=https://api.github.com/user
NESTRS_AUTHN__REDIRECT_URL=http://localhost:3002/callback
NESTRS_AUTHN__SCOPES=["read:user"]

# OpenAPI document identity for the `api` app (title/version default to "nestrs
# API" / "0.1.0"; only the description differs from the defaults here).
NESTRS_OPENAPI__DESCRIPTION=Demo API built with nestrs
